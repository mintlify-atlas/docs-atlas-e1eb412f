{
  "$schema": "https://mintlify.com/docs.json",
  "name": "doc-kit",
  "theme": "aspen",
  "colors": {
    "primary": "#339933",
    "light": "#68BB59",
    "dark": "#026E00"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/nodejs/doc-kit"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/nodejs/doc-kit"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Commands",
            "pages": [
              "commands/generate",
              "commands/interactive"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/overview",
              "configuration/file-format",
              "configuration/cli-options"
            ]
          },
          {
            "group": "Generators",
            "pages": [
              "generators/overview",
              "generators/built-in",
              "generators/creating-custom",
              "generators/parallel-processing"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/architecture",
              "advanced/worker-threads",
              "advanced/streaming",
              "advanced/custom-commands",
              "advanced/comparators"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core API",
            "pages": [
              "api/generators",
              "api/configuration",
              "api/logger",
              "api/metadata",
              "api/parsers"
            ]
          },
          {
            "group": "Generator Types",
            "pages": [
              "api/generators/web",
              "api/generators/legacy-html",
              "api/generators/legacy-json",
              "api/generators/json-simple",
              "api/generators/man-page",
              "api/generators/orama-db",
              "api/generators/llms-txt",
              "api/generators/addon-verify",
              "api/generators/api-links",
              "api/generators/sitemap"
            ]
          },
          {
            "group": "Utilities",
            "pages": [
              "api/utils/streaming",
              "api/utils/threading",
              "api/utils/file-operations"
            ]
          }
        ]
      }
    ]
  }
}
